<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- The real theming (colors, typography, dark/light) lives in Kotlin
         under ui/theme/ via Compose MaterialTheme. This XML theme only
         controls the pre-Compose window background / splash so there is
         no flash of an unstyled window before Compose takes over. -->
    <style name="Theme.ReconX" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">#1A0F14</item>
        <item name="android:windowBackground">#1A0F14</item>
        <item name="android:navigationBarColor">#1A0F14</item>
    </style>
</resources>
